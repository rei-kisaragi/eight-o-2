{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "eight-o-2",
	"compatibility_date": "2026-06-06",
	"main": ".svelte-kit/cloudflare/_worker.js",
	"assets": {
		"directory": ".svelte-kit/cloudflare"
	},
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true
	}
}