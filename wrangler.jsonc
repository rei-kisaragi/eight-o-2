{
    "$schema": "./node_modules/wrangler/config-schema.json",
    "name": "eight-o-2",
    "main": ".svelte-kit/cloudflare/_worker.js",
    "compatibility_date": "2026-06-06",
    "compatibility_flags": [
        "nodejs_als"
    ],
    "assets": {
        "binding": "ASSETS",
        "directory": ".svelte-kit/cloudflare"
    },
    "observability": {
        "enabled": true
    }
}